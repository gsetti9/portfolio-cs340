<div class="question text-question" 
     data-type="Text" 
     data-question-number="<%= questionNumber %>">

  <label>Question:</label>
  <textarea class="question-text" placeholder="Enter your question here"></textarea>

  <label>Answer:</label>
  <textarea class="question-answer" placeholder="Enter the correct answer here"></textarea>

  <button type="button" class="remove-question-btn">Remove Question</button>
</div>